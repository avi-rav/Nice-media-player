# Copy to a shell env var before running the dev server. NEVER commit a real key.
#   PowerShell:  $env:PEXELS_API_KEY = "your_pexels_api_key"; npm start
#   bash:        PEXELS_API_KEY=your_pexels_api_key npm start
#
# Get a free key at https://www.pexels.com/api/
PEXELS_API_KEY=your_pexels_api_key
